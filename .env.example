# Push targets (at least one required)
DISCORD_WEBHOOK_URL=
NTFY_TOPIC_URL=https://ntfy.sh/your-private-topic-here

# Optional ntfy auth (if using a private server)
NTFY_TOKEN=

# Polling cadence (seconds). Lower during active sale windows, raise normally.
POLL_SHIP_MATRIX_SEC=300
POLL_PLEDGE_STORE_SEC=60
POLL_COMM_LINK_SEC=60

# State file (JSON). Holds last-seen IDs so we only notify on diff.
STATE_FILE=/home/ubuntu/projects/sc-drop-watcher/.state.json

# Identify ourselves honestly to RSI ops.
USER_AGENT=sc-drop-watcher/0.1 (personal monitor; contact: Sergentval@hotmail.fr)

# Set to "1" to actually send pushes; "0" prints what *would* be sent.
LIVE=0

# Watchlist — comma-separated `ship:mode` pairs. Mode is optional; defaults
# to "any". Modes: warbond (or "wb") | store-credit (or "sc" / "credit") | any.
# When a detection's title or URL contains your ship name AND matches the
# warbond preference, the push is escalated: red Discord embed + "WATCH"
# tag + ntfy max-priority + alarm tag (your phone vibrates differently).
# Examples:
#   WATCHLIST=Polaris:warbond
#   WATCHLIST=Polaris:wb,Idris:any,Galaxy:credit
#   WATCHLIST=Polaris,Idris       # both default to "any" mode
WATCHLIST=

# URL probe — for ships not yet on the site (ODIN, Apollo, etc). The daemon
# does a HEAD request on each URL every PROBE_INTERVAL_SEC. When a previously
# 4xx URL flips to 2xx (page goes live), fires a watchlist-priority push.
# When 2xx → 4xx (page taken down), fires a removed-priority push.
# First observation is silent.
#
# Use full https:// URLs, comma-separated. Both URL shapes are worth probing
# for an upcoming ship since you don't know which path RSI will use:
#   PROBE_URLS=https://robertsspaceindustries.com/en/pledge/Standalone-Ships/ODIN,https://robertsspaceindustries.com/en/pledge/Standalone-Ships/ODIN-Warbond
PROBE_URLS=
PROBE_INTERVAL_SEC=120
