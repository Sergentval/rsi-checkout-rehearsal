# Push targets (at least one required)
DISCORD_WEBHOOK_URL=
NTFY_TOPIC_URL=https://ntfy.sh/your-private-topic-here

# Optional ntfy auth (if using a private server)
NTFY_TOKEN=

# Polling cadence (seconds). Lower during active sale windows, raise normally.
POLL_SHIP_MATRIX_SEC=300
POLL_PLEDGE_STORE_SEC=60
POLL_COMM_LINK_SEC=60

# State file (JSON). Holds last-seen IDs so we only notify on diff.
STATE_FILE=/home/ubuntu/projects/sc-drop-watcher/.state.json

# Identify ourselves honestly to RSI ops.
USER_AGENT=sc-drop-watcher/0.1 (personal monitor; contact: Sergentval@hotmail.fr)

# Set to "1" to actually send pushes; "0" prints what *would* be sent.
LIVE=0
